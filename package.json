{
  "name": "easy-index",
  "version": "0.1.0",
  "description": "Bitcoin market awareness tray app",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "keywords": [],
  "author": "Nathan G. Santos",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "electron-store": "^8.2.0",
    "node-fetch": "^2.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js"
    }
  }
}
