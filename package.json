{
  "name": "easy-index",
  "version": "0.1.0",
  "description": "Bitcoin market awareness tray app",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "build": "electron-builder",
    "build:all": "electron-builder --win --mac --linux",
    "build:ci": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir || true"
  },
  "keywords": [],
  "author": "Nathan G. Santos",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "node-fetch": "^2.7.0"
  },
  "build": {
    "appId": "com.easyindex.app",
    "productName": "Easy Index",
    "publish": {
      "provider": "github"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "artifactName": "Easy-Index-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js"
    }
  }
}
